{
  "auths": {},
  "credsStore": "osxkeychain",
  "plugins": {
    "debug": {
      "hooks": "exec"
    },
    "scout": {
      "hooks": "pull,buildx build"
    }
  },
  "features": {
    "hooks": "true"
  },
  "credHelpers": {
    {{- if eq .workDevice true }}
    {{ .workPrivateEcrRegistry }}: "ecr-login",
    {{- end }}
    {{- if .privateEcrRegistry }}
    {{ .privateEcrRegistry }}: "ecr-login",
    {{- end }}
    "public.ecr.aws": "ecr-login"
  }
}
